///|
/// 导出数据治理状态的 HTML 报告
pub fn generate_html_report(
  dataset : @core.Dataset,
  fleiss_res : @agreement.FleissKappaResult,
  alpha_res : @agreement.KrippendorffAlphaResult,
  stats_res : @stats.LabelDistribution,
  outliers : Array[@quality.OutlierReport],
  conflicts : Array[@quality.LabelConflictItem],
) -> String {
  let title = "MoonLabelKit 质量评估报告: " + dataset.name

  let mut issue_list = ""
  if outliers.length() == 0 && conflicts.length() == 0 {
    issue_list = "<li>🎉 完美！未检测到任何数据冲突或格式异常。</li>"
  } else {
    for outlier in outliers {
      issue_list = issue_list +
        "<li>❌ [" +
        outlier.issue_type +
        "] " +
        outlier.description +
        "</li>\n"
    }
    for conflict in conflicts {
      issue_list = issue_list +
        "<li>⚠️ [标签冲突] 样本 " +
        conflict.sample_id +
        " 存在 " +
        conflict.conflict_severity +
        "</li>\n"
    }
  }

  let html = "<!DOCTYPE html>\n" +
    "<html lang=\"zh-CN\">\n" +
    "<head>\n" +
    "  <meta charset=\"UTF-8\">\n" +
    "  <title>" +
    title +
    "</title>\n" +
    "  <style>\n" +
    "    body { font-family: sans-serif; background: #f7f9fc; color: #333; margin: 0; padding: 20px; }\n" +
    "    .container { max-width: 900px; margin: 0 auto; background: #fff; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }\n" +
    "    h1 { color: #2c3e50; border-bottom: 2px solid #3498db; padding-bottom: 10px; }\n" +
    "    h2 { color: #34495e; margin-top: 30px; }\n" +
    "    .card { background: #f8f9fa; border-left: 4px solid #3498db; padding: 15px; margin-bottom: 20px; border-radius: 4px; }\n" +
    "    .metrics { display: flex; flex-wrap: wrap; gap: 20px; }\n" +
    "    .metric-box { flex: 1; min-width: 200px; background: #fff; border: 1px solid #e1e4e8; border-radius: 6px; padding: 15px; text-align: center; }\n" +
    "    .metric-value { font-size: 24px; font-weight: bold; color: #2980b9; margin-top: 10px; }\n" +
    "    ul { line-height: 1.6; }\n" +
    "    .footer { margin-top: 40px; text-align: center; color: #7f8c8d; font-size: 14px; }\n" +
    "  </style>\n" +
    "</head>\n" +
    "<body>\n" +
    "  <div class=\"container\">\n" +
    "    <h1>🌌 " +
    title +
    "</h1>\n" +
    "    \n" +
    "    <h2>📊 数据集概览</h2>\n" +
    "    <div class=\"metrics\">\n" +
    "      <div class=\"metric-box\"><div>总样本数</div><div class=\"metric-value\">" +
    dataset.samples.length().to_string() +
    "</div></div>\n" +
    "      <div class=\"metric-box\"><div>类别数量</div><div class=\"metric-value\">" +
    dataset.schema_labels.length().to_string() +
    "</div></div>\n" +
    "      <div class=\"metric-box\"><div>标注总数</div><div class=\"metric-value\">" +
    stats_res.total_annotations.to_string() +
    "</div></div>\n" +
    "    </div>\n" +
    "\n" +
    "    <h2>📈 分布与一致性分析</h2>\n" +
    "    <div class=\"card\">\n" +
    "      <p><strong>香农信息熵 (Entropy):</strong> " +
    stats_res.shannon_entropy.to_string() +
    " <em>(熵值越高，类别分布越均匀)</em></p>\n" +
    "      <p><strong>基尼不平衡系数 (Gini):</strong> " +
    stats_res.gini_imbalance.to_string() +
    " <em>(0表示绝对平衡，接近1表示极度长尾失衡)</em></p>\n" +
    "      <hr/>\n" +
    "      <p><strong>Fleiss' Kappa (&#954;):</strong> " +
    fleiss_res.kappa_score.to_string() +
    " - <em>" +
    fleiss_res.interpretation +
    "</em></p>\n" +
    "      <p><strong>Krippendorff's Alpha (&#945;):</strong> " +
    alpha_res.alpha_score.to_string() +
    " - <em>" +
    alpha_res.interpretation +
    "</em></p>\n" +
    "    </div>\n" +
    "\n" +
    "    <h2>🚨 数据治理巡检结果 (Issues)</h2>\n" +
    "    <div class=\"card\" style=\"border-left-color: #e74c3c;\">\n" +
    "      <ul style=\"list-style-type: none; padding-left: 0;\">\n" +
    "        " +
    issue_list +
    "\n" +
    "      </ul>\n" +
    "    </div>\n" +
    "\n" +
    "    <div class=\"footer\">\n" +
    "      Generated by <a href=\"https://github.com/Zy789kl/moonlabelkit\" target=\"_blank\">MoonLabelKit</a> - The High-Performance Data Governance Engine.\n" +
    "    </div>\n" +
    "  </div>\n" +
    "</body>\n" +
    "</html>"

  html
}
